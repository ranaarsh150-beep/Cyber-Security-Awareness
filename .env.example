# MongoDB connection (use mongo hostname in Docker: mongodb://mongo:27017/cybershield)
MONGODB_URI=mongodb://127.0.0.1:27017/cybershield

# JWT signing (min 16 characters; use a long random string in production)
JWT_SECRET=replace-with-a-long-random-secret-key

# Optional: token lifetime (default 7d)
# JWT_EXPIRES_IN=7d

# Seed script defaults (optional overrides)
# SEED_ADMIN_EMAIL=admin@cybershield.local
# SEED_ADMIN_PASSWORD=ChangeMe123!
